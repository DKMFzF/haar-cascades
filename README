haar cascades practica

env backend
FACE_CASCADE_PATH=docs/haarcascade_frontalface_alt.xml
EYES_CASCADE_PATH=docs/haarcascade_eye_tree_eyeglasses.xml
CAMERA_INDEX=0

env frontend
Copy frontend/.env.local.example to frontend/.env.local.

run backend API
cd backend && task install && task api

run frontend
cd frontend && npm install && npm run dev

optional desktop mode
cd backend && task run

link for dataset https://github.com/opencv/opencv/blob/master/data/haarcascades/haarcascade_frontalface_default.xml
link for dataset https://github.com/opencv/opencv/blob/master/data/haarcascades/haarcascade_eye_tree_eyeglasses.xml
link for dataset https://github.com/opencv/opencv/blob/master/data/haarcascades/haarcascade_frontalface_alt.xml
